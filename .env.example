TELEGRAM_BOT_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_gemini_api_key
SUPABASE_URL=https://your-project.supabase.co/rest/v1/
SUPABASE_KEY=your_supabase_key

# For Google Drive API
# If using a service account (recommended), provide the path to your JSON key file:
GOOGLE_APPLICATION_CREDENTIALS=path\to\credentials.json

# Provide the Google Drive Folder ID where you want to upload the monthly reports
DRIVE_FOLDER_ID=your_drive_folder_id

# Restrict bot access to specific Telegram user IDs only (comma-separated)
# Leave empty to allow anyone. Get your ID from @userinfobot.
ALLOWED_USER_IDS=
